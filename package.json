{
  "name": "eligius",
  "author": "Roland Zwaga <rbzwaga@gmail.com>",
  "version": "2.2.1",
  "license": "MIT",
  "homepage": "https://rolandzwaga.github.io/eligius/",
  "bugs": {
    "url": "https://github.com/rolandzwaga/eligius/issues?q=is%3Aissue+is%3Aopen+label%3ABug"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ]
    }
  },
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "jsonschema"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --pretty --noEmit",
    "test": "vitest --config src/vitest.config.ts",
    "test:ci": "vitest run --config src/vitest.config.ts --reporter=verbose",
    "test:coverage": "vitest --config src/vitest.config.ts --coverage",
    "generate-readmes": "tsx ./src/tools/doc-tools/generate-readmes",
    "generate-schema": "tsx ./src/tools/schema-tools/generate-schemas",
    "typedoc": "typedoc --options typedoc-metadata.json & typedoc --options typedoc.json",
    "docs": "npm run generate-schema && npm run typedoc && node copy-schema && npm run generate-readmes",
    "opers-metadata": "tsx src/tools/code-generator/metadata-generator.ts",
    "ctrls-metadata": "tsx src/tools/code-generator/ctrls-metadata-generator.ts",
    "events-metadata": "tsx src/tools/code-generator/events-metadata-generator.ts",
    "metadata": "npm run opers-metadata && npm run ctrls-metadata && npm run events-metadata",
    "ts-types": " tsc --noEmit false --emitDeclarationOnly --outDir dist",
    "build": "rimraf dist && npm run metadata && npm run generate-schema && tsdown",
    "codemod": "tsx src/tools/code-generator/uvu2vitest-codemod.ts",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@rollup/plugin-alias": "6.0.0",
    "@types/fs-extra": "11.0.4",
    "@types/jquery": "4.0.0",
    "@types/jsdom": "28.0.1",
    "@types/node": "25.7.0",
    "@types/uuid": "11.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260427.1",
    "@vitest/coverage-istanbul": "4.1.5",
    "fs-extra": "11.3.4",
    "jquery": "4.0.0",
    "jsdom": "29.1.0",
    "lottie-web": "5.13.0",
    "rimraf": "6.1.3",
    "ts-json-schema-generator": "2.9.0",
    "ts-morph": "28.0.0",
    "tsdown": "0.21.10",
    "tsx": "4.21.0",
    "typedoc": "0.28.19",
    "video.js": "8.23.7",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "jquery": "4.0.0",
    "lottie-web": "5.13.0",
    "video.js": "8.23.7"
  },
  "dependencies": {
    "hotkeys-js": "4.0.3",
    "rosetta": "1.1.0",
    "ts-is-present": "1.2.2",
    "uuid": "14.0.0"
  },
  "types": "./dist/index.d.mts"
}
